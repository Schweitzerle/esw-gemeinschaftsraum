# Gemeinsames Haus-Passwort (wird in der WhatsApp-Gruppe geteilt)
HAUS_PASSWORT=bitte-aendern

# Secret zum Signieren des Session-Cookies (mind. 32 Zeichen, z. B. `openssl rand -hex 32`)
SESSION_SECRET=bitte-durch-64-hex-zeichen-ersetzen

# Pfad zur SQLite-Datei (Verzeichnis muss existieren; als Volume mounten)
DATABASE_PATH=data/gemeinschaftsraum.db

# Öffentliche URL der Seite (nötig für Formular-CSRF-Schutz hinter Reverse Proxy)
ORIGIN=https://gemeinschaftsraum.example.de

# Port des Node-Prozesses (Default 3000)
PORT=3000
